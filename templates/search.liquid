<div class="container">
  <h1>Search Results</h1>
  {% if search.results_count > 0 %}
    <p>{{ search.results_count }} results for "{{ search.terms }}"</p>
    <div class="product-grid">
      {% for item in search.results %}
        {% if item.object_type == 'product' %}
          <div class="product-card">
            <img src="{{ item.featured_image | img_url: 'medium' }}" alt="{{ item.title }}">
            <div class="product-info">
              <h3 class="product-title">{{ item.title }}</h3>
              <p class="product-price">{{ item.price | money }}</p>
              <a href="{{ item.url }}" class="btn">View Product</a>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  {% else %}
    <p>No results found for "{{ search.terms }}"</p>
  {% endif %}
</div>